  24          /**********************************************************************
  25          * 名称 : ANT_UART1_Initl(uint32_t uBaud)
  26          * 功能 : 串口1初始化函数
  27          * 输入 : uBaud -- 波特率
  28          * 输出 ：无
  29          * 说明 : 无
  30          ***********************************************************************/
  31          void ANT_UART1_Initl(uint32_t uBaud)
  32          {
  33   1      #if (PARITYBIT == NONE_PARITY)
  34   1          SCON = 0x50;            //8-bit variable UART
  35   1      #elif (PARITYBIT == ODD_PARITY) || (PARITYBIT == EVEN_PARITY) || (PARITYBIT == MARK_PARITY)
                  SCON = 0xda;            //9-bit variable UART, parity bit initial to 1
              #elif (PARITYBIT == SPACE_PARITY)
                  SCON = 0xd2;            //9-bit variable UART, parity bit initial to 0
              #endif
  40   1      
  41   1          TMOD = 0x20;            //Set Timer1 as 8-bit auto reload mode
  42   1          TH1 = TL1 = -(F_cpu / 12 / 32 / uBaud); //Set auto-reload vaule
  43   1          TR1 = 1;                //Timer1 start run
  44   1          ES = 1;                 //Enable UART interrupt
  45   1          EA = 1;                 //Open master interrupt switch
  46   1              TI = 1;                                 //printf
  47   1      
  48   1              u1_Busy = Idle;
  49   1      }
  50          /**********************************************************************
  51          * 名称 : ANT_UART1_SendByte(uint8_t value)
  52          * 功能 : 串口1单字节发送函数
  53          * 输入 : value -- 数据
C51 COMPILER V8.08   ANT_UART1                                                             12/15/2025 19:53:30 PAGE 2   

  54          * 输出 ：无
  55          * 说明 : 无
  56          ***********************************************************************/
  57          void ANT_UART1_SendByte(uint8_t value)
  58          {
  59   1          while (u1_Busy);            //Wait for the completion of the previous data is sent
  60   1          ACC = value;                //Calculate the even parity bit P (PSW.0)
  61   1          if (P)                  //Set the parity bit according to P
  62   1          {
  63   2      #if (PARITYBIT == ODD_PARITY)
                      TB8 = 0;            //Set parity bit to 0
              #elif (PARITYBIT == EVEN_PARITY)
                      TB8 = 1;            //Set parity bit to 1
              #endif
  68   2          }
  69   1          else
  70   1          {
  71   2      #if (PARITYBIT == ODD_PARITY)
                      TB8 = 1;            //Set parity bit to 1
              #elif (PARITYBIT == EVEN_PARITY)
                      TB8 = 0;            //Set parity bit to 0
              #endif
  76   2          }
  77   1          u1_Busy = Busy;
  78   1          SBUF = ACC;             //Send data to UART buffer
  79   1      }
  80          /**********************************************************************
  81          * 名称 : ANT_UART1_SendString(char *s)
  82          * 功能 : 串口1字符串发送函数
  83          * 输入 : *s -- 字符串
  84          * 输出 ：无
  85          * 说明 : 无
  86          ***********************************************************************/
  87           void ANT_UART1_SendString(char *s)
  88          {
  89   1          while (*s)              //Check the end of the string
  90   1          {
  91   2              ANT_UART1_SendByte(*s++);     //Send current char and increment string ptr
  92   2          }
  93   1      }
  94          /**********************************************************************
  95          * 名称 : ANT_UART1_ISR(void) interrupt 4
  96          * 功能 : 串口1中断服务程序
  97          * 输入 : 无
  98          * 输出 ：无
  99          * 说明 : 无
 100          ***********************************************************************/
 101          void ANT_UART1_ISR(void) interrupt 4
 102          {
 103   1              //1.接收中断
 104   1          if (RI)
 105   1          {
 106   2              RI = 0;             //Clear receive interrupt flag
 107   2          }
 108   1              //2.发送中断
 109   1          else if (TI)
 110   1          {
 111   2              TI = 0;             //Clear transmit interrupt flag
 112   2             u1_Busy = Idle;          //Clear transmit busy flag
 113   2          }
 114   1      }
