  32          * ГыіЖ : TMP119_Write_Register(uint8_t nSLA,REG_Def nReg,uint16_t value)
  33          * №ҰДЬ : РҙјДҙжЖчәҜКэ
  34          * КдИл : nSLA -- ЙиұёөШЦ·
  35                           nReg -- јДҙжЖч
  36                           value -- КэҫЭ
  37          * Кдіц ЈәОЮ
  38          * ЛөГч : ОЮ
  39          ***********************************************************************/
  40          void TMP119_Write_Register(uint8_t nSLA,REG_Def nReg,uint16_t value)
  41          {
  42   1              I2C_Buffer[0] = nReg;                                   //СЎФсТӘРҙИлөДјДҙжЖч
  43   1              I2C_Buffer[1] = value >> 8;             
  44   1              I2C_Buffer[2] = value >> 0;
  45   1              ANT_I2C_Wtite_nByte(nSLA,I2C_Buffer,3); 
  46   1      }
  47          /**********************************************************************
  48          * ГыіЖ : TMP119_Read_Register(uint8_t nSLA,REG_Def nReg)
  49          * №ҰДЬ : ҙУЦё¶ЁјДҙжЖч¶БКэҫЭ
  50          * КдИл : nSLA -- ЙиұёөШЦ·
  51                           nReg -- Цё¶ЁјДҙжЖч
  52          * Кдіц Јәreg_value -- јДҙжЖчКэҫЭ
  53          * ЛөГч : ОЮ
C51 COMPILER V8.08   TMP119_EVM                                                            12/15/2025 19:53:30 PAGE 2   

  54          ***********************************************************************/
  55          uint16_t TMP119_Read_Register(uint8_t nSLA,REG_Def nReg)
  56          {
  57   1              uint16_t reg_value = 0x00;
  58   1      
  59   1              I2C_Buffer[0] = nReg;                                   //СЎФсТӘ¶БИЎөДјДҙжЖч
  60   1              ANT_I2C_Wtite_nByte(nSLA,I2C_Buffer,1); //РҙPointer Register
  61   1              delay_15us();                                                   //СУКұ15us
  62   1              ANT_I2C_Read_nByte(nSLA,I2C_Buffer,2);  //¶БјДҙжЖч
  63   1              
  64   1              reg_value = I2C_Buffer[0];                              //ЧйәПКэҫЭ 
  65   1              reg_value = (reg_value << 8) + I2C_Buffer[1];
  66   1              
  67   1              return reg_value;
  68   1      }
