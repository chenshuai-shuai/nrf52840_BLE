 123          /**********************************************************************
 124          * ГыіЖ : TMP119_Write_EEPROM(REG_Def nReg,uint16_t value)
 125          * №ҰДЬ : РҙEEPROMјДҙжЖчәҜКэ
 126          * КдИл : nReg -- јДҙжЖч
 127                           value -- КэҫЭ
 128          * Кдіц ЈәЧҙМ¬Јә0 -- іЙ№ҰЈ¬1 -- К§°Ь
 129          * ЛөГч : ОЮ
 130          ***********************************************************************/
 131          uint8_t TMP119_Write_EEPROM(REG_Def nReg,uint16_t value)
 132          {
 133   1              EEPROM_UL_REG.WORD = 0x00;                              //ёҙО»јДҙжЖч
 134   1              if(nReg == REG_EEPROM2 || nReg == REG_EEPROM3)          //ОӘЦ§іЦNISTөДҝЙЧ·ЛЭРФЈ¬ЗРОр¶ФEEPROM1ҪшРРұаіМ
 135   1              {
 136   2                      EEPROM_UL_REG.BIT.EUN = 1;                      //ҪвЛш  
 137   2                      TMP119_Write_Register(TMP_SLA,REG_EEPROM_UL,EEPROM_UL_REG.WORD);                //РҙИлјДҙжЖчөИҙэҪвЛшіЙ№Ұ
 138   2                      delay_ms(8);                                            //өИҙэ8ms
 139   2                      EEPROM_UL_REG.WORD = TMP119_Read_Register(TMP_SLA,REG_EEPROM_UL);               //»Ш¶БјДҙжЖчөДЦө
 140   2                      if(EEPROM_UL_REG.BIT.EEPROM_Busy == 0)                  //ҪвЛшіЙ№Ұ
 141   2                      {
 142   3                              TMP119_Write_Register(TMP_SLA,nReg,value);      //ұаіМEEPROM
 143   3                      }
 144   2                      else return 1;                                          //ҪвЛшК§°Ь
 145   2              }
 146   1              return 0;
 147   1      }
