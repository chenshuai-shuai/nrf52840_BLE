 149          * 名称 : ANT_I2C_Wtite_nByte(uint8_t Device_Addr,uint8_t *buf,uint16_t Length)
 150          * 功能 : I2C向指定设备写n个字节函数
 151          * 输入 : Device_Addr -- 设备地址(从机地址)
 152                           *buf -- 数据
 153                           Length -- 写入长度
 154          * 输出 ：无
 155          * 说明 : 无
 156          ***********************************************************************/
 157          void ANT_I2C_Wtite_nByte(uint8_t Device_Addr,uint8_t *buf,uint16_t Length)
 158          {
 159   1              uint16_t i = 0;
 160   1      
 161   1              I2C_Start();            //起始信号
 162   1              I2C_Send_Byte(Device_Addr | I2C_WRITE);         //发送设备地址+写信号   
 163   1              I2C_Wait_Ack();
 164   1              delay_10us();                   //延迟10us
 165   1              for(i = 0;i < Length;i ++)
 166   1              {
 167   2                      I2C_Send_Byte(*buf ++);                                 //写入数据
 168   2                      I2C_Wait_Ack();  
 169   2                      delay_10us();           //延迟10us
 170   2              }
 171   1              I2C_Stop();             //停止信号
 172   1              delay_15us();                   //延迟15us
 173   1      }
