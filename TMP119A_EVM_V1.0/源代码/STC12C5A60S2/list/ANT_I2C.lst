 197   2                      else I2C_Send_N_Ack(I2C_ACK);                   //应答信号
 198   2      
 199   2                      delay_10us();           //延迟10us
 200   2              }
 201   1              I2C_Stop();             //停止信号
 202   1              delay_15us();                   //延迟15us      
