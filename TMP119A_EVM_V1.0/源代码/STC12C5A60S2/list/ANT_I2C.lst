 183          void ANT_I2C_Read_nByte(uint8_t Device_Addr,uint8_t *buf,uint16_t Length)
 184          {
 185   1              uint16_t i = 0;
 186   1      
 187   1              I2C_Start();                    //起始信号
 188   1              I2C_Send_Byte(Device_Addr | I2C_READ);          //发送设备地址+读信号
 189   1              I2C_Wait_Ack();
 190   1              delay_10us();                   //延迟10us
 191   1              for(i = 0;i < Length;i ++)
 192   1              {
 193   2                      *buf ++ = I2C_Read_Byte();                              //接收数据
 194   2                      
